<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/schedule_card_fragment_patient"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/registry_card_fragment_patient_imageview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/patient_picture_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:srcCompat="@drawable/icons8_test_account_32" />

    <TextView
        android:id="@+id/registry_card_fragment_patient_textview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textAllCaps="true"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/registry_card_fragment_patient_imageview"
        app:layout_constraintStart_toEndOf="@+id/registry_card_fragment_patient_imageview"
        app:layout_constraintTop_toTopOf="@+id/registry_card_fragment_patient_imageview"
        app:layout_constraintVertical_bias="0.25"
        tools:text="carlos lacerda filho" />
</androidx.constraintlayout.widget.ConstraintLayout>